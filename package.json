{
  "name": "onlystack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "schema:validate": "npx sentinel schema:validate",
    "schema:generate": "npx sentinel schema:generate",
    "sentinel:all": "npx sentinel all",
    "validate:fixtures": "node scripts/validate-fixtures.js",
    "build:backend": "cd apps/starter-api && npm run build",
    "build:ios": "cd apps/starter-ios && xcodebuild -project StarterApp.xcodeproj -scheme 'StarterApp-Dev' -destination 'generic/platform=iOS Simulator' build",
    "build:android": "cd apps/starter-android && ./gradlew :app:compileMockDebugKotlin",
    "test:backend": "cd apps/starter-api && npm test",
    "test:e2e": "cd apps/starter-api && npm run test:e2e"
  },
  "devDependencies": {
    "sentinel": "file:../sentinel"
  }
}
