# Fastfile — Android CI/CD lanes for StarterApp
#
# Prerequisites before using any lane:
#   1. Install Fastlane:  cd apps/starter-android && bundle install
#   2. Set up your signing keystore and export these environment variables:
#        KEYSTORE_PATH        — absolute path to your .jks / .keystore file
#        KEYSTORE_PASSWORD    — store password
#        KEY_ALIAS            — key alias inside the keystore
#        KEY_PASSWORD         — key password
#      For local development, place these in a .env file (gitignored).
#      For CI, configure them as secret environment variables in your CI provider.
#   3. For the beta/release lanes, ensure google-play-key.json is present
#      (see fastlane/Appfile for instructions).

default_platform(:android)

platform :android do

  # ---------------------------------------------------------------------------
  # test — run all unit tests for the dev flavor
  # ---------------------------------------------------------------------------
  # Usage: bundle exec fastlane android test
  #
  # Runs the JUnit 5 test suite via Gradle on the dev/Debug variant.
  # No signing or Play Store credentials required.
  # ---------------------------------------------------------------------------
  lane :test do
    gradle(
      task:       "test",
      flavor:     "dev",
      build_type: "Debug",
    )
  end

  # ---------------------------------------------------------------------------
  # beta — build a prod Release AAB and upload to Play Store internal track
  # ---------------------------------------------------------------------------
  # Usage: bundle exec fastlane android beta
  #
  # TODO: Before first run —
  #   • Ensure KEYSTORE_PATH / KEYSTORE_PASSWORD / KEY_ALIAS / KEY_PASSWORD are set.
  #   • Ensure fastlane/google-play-key.json is in place (see Appfile).
  #   • The first upload to Play Store must be done manually via the web console;
  #     subsequent uploads can use this lane.
  # ---------------------------------------------------------------------------
  lane :beta do
    # Bump the versionCode by 1 in app/build.gradle.kts so each upload is unique.
    increment_version_code(
      gradle_file_path: "app/build.gradle.kts",
    )

    gradle(
      task:        "bundle",
      flavor:      "prod",
      build_type:  "Release",
      properties:  {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      },
    )

    upload_to_play_store(
      track:              "internal",
      release_status:     "draft",   # change to "completed" once reviewed
      skip_upload_apk:    true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  # ---------------------------------------------------------------------------
  # release — build a prod Release AAB and promote to production track
  # ---------------------------------------------------------------------------
  # Usage: bundle exec fastlane android release
  #
  # Same signing and credential requirements as the beta lane.
  # Use this after the internal build has been validated.
  # ---------------------------------------------------------------------------
  lane :release do
    increment_version_code(
      gradle_file_path: "app/build.gradle.kts",
    )

    gradle(
      task:        "bundle",
      flavor:      "prod",
      build_type:  "Release",
      properties:  {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      },
    )

    upload_to_play_store(
      track:              "production",
      release_status:     "completed",
      skip_upload_apk:    true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

end
