{
  "$sentinel": "1.0",
  "type": "feature",
  "id": "auth",
  "name": "Unified Authentication",
  "milestone": "M1",
  "platforms": ["ios", "android", "api", "web"],
  "canonicalDoc": "docs/AUTH_SYSTEM.md",
  "capabilities": [
    "email_challenge_request",
    "email_code_entry",
    "email_deep_link_resume",
    "apple_sign_in",
    "google_sign_in",
    "refresh",
    "logout",
    "mock_mode_auth",
    "console_delivery_mode"
  ],
  "models": ["user"],
  "flags": [],
  "strings": [
    "auth.welcome.title",
    "auth.welcome.subtitle",
    "auth.welcome.signIn",
    "auth.email.title",
    "auth.email.placeholder",
    "auth.email.continue",
    "auth.code.title",
    "auth.code.subtitle",
    "auth.code.verify",
    "auth.code.resend",
    "auth.code.resendIn",
    "auth.social.apple",
    "auth.social.google",
    "auth.magic_link.open_app",
    "auth.magic_link.check_email",
    "auth.error.invalidCode",
    "auth.error.expired",
    "auth.error.rateLimited",
    "auth.logout",
    "common.loading",
    "common.error.generic",
    "common.error.network"
  ],
  "verification": {
    "requiredProof": [
      "welcome-screen",
      "email-entry",
      "code-entry",
      "auth-deep-link-open",
      "post-auth-destination"
    ],
    "simulator": "simemu",
    "automation": "maestro"
  }
}
