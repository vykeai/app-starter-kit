# Onlystack — Root Environment Variables
# Copy relevant values into apps/starter-api/.env for local development

# ── Server ────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onlystack_dev

# ── Authentication ────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-32-char-minimum-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15

# ── Redis (BullMQ queues) ─────────────
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ──────────────────────
# Leave blank to use console logging in development
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourapp.com
RESEND_API_KEY=

# ── Search ────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# ── Object Storage (Cloudflare R2) ────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=onlystack-media-dev
R2_PUBLIC_BASE_URL=

# ── Hosting / App URLs ────────────────
APP_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3001
WEB_ADMIN_URL=http://localhost:3002
WEB_PUBLIC_URL=http://localhost:4321

# ── App Version Enforcement ───────────
APP_VERSION_IOS_CURRENT=1.0.0
APP_VERSION_IOS_MINIMUM=1.0.0
APP_VERSION_ANDROID_CURRENT=1.0.0
APP_VERSION_ANDROID_MINIMUM=1.0.0

# ── Firebase (optional, for push notifications) ──
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
