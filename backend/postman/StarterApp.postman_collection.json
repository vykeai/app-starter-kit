{
  "info": {
    "name": "StarterApp API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Complete API collection for StarterApp. Covers health, app version, auth (magic link), and user profile endpoints.\n\nWorkflow:\n1. Run **Auth / Request Magic Link** — check email (or dev console) for OTP.\n2. Run **Auth / Verify Magic Link** — paste OTP into `code` field; the test script saves `access_token` and `refresh_token` to collection variables automatically.\n3. All authenticated requests pick up `{{access_token}}` from the collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "description": "Server liveness check. No authentication required.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns server status and current UTC timestamp. This endpoint bypasses rate-limiting."
          },
          "response": [
            {
              "name": "200 OK — server healthy",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"status\": \"ok\",\n  \"timestamp\": \"2026-03-04T12:00:00.000Z\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});",
                  "",
                  "pm.test('Response has timestamp', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.timestamp).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "App Version",
      "description": "Client app version check. Returns whether an update is required or recommended.",
      "item": [
        {
          "name": "Version Check (iOS)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/app/version-check?platform=ios&version=1.0.0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "app", "version-check"],
              "query": [
                { "key": "platform", "value": "ios", "description": "Client platform: ios | android" },
                { "key": "version", "value": "1.0.0", "description": "Semver string of the installed app" }
              ]
            },
            "description": "Check whether the running client version is still supported. Returns `isUpdateRequired` (hard gate) and `isUpdateRecommended` (soft prompt)."
          },
          "response": [
            {
              "name": "200 OK — no update required",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"isUpdateRequired\": false,\n  \"isUpdateRecommended\": false,\n  \"minimumVersion\": \"1.0.0\",\n  \"latestVersion\": \"1.0.0\"\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "200 OK — update recommended",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"isUpdateRequired\": false,\n  \"isUpdateRecommended\": true,\n  \"minimumVersion\": \"1.0.0\",\n  \"latestVersion\": \"1.2.0\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Version check returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has required fields', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('isUpdateRequired');",
                  "  pm.expect(json).to.have.property('isUpdateRecommended');",
                  "  pm.expect(json).to.have.property('minimumVersion');",
                  "  pm.expect(json).to.have.property('latestVersion');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Version Check (Android)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/app/version-check?platform=android&version=1.0.0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "app", "version-check"],
              "query": [
                { "key": "platform", "value": "android" },
                { "key": "version", "value": "1.0.0" }
              ]
            },
            "description": "Same as iOS version check but for Android clients."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"isUpdateRequired\": false,\n  \"isUpdateRecommended\": false,\n  \"minimumVersion\": \"1.0.0\",\n  \"latestVersion\": \"1.0.0\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Version check returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Magic link (email OTP) authentication flow.\n\n**Order of operations:**\n1. Request Magic Link → OTP arrives in email (or dev console stdout)\n2. Verify Magic Link → saves `access_token` + `refresh_token` to collection variables\n3. Refresh Token → rotates tokens\n4. Logout (single session) → revokes one refresh token\n5. Logout (all sessions) → invalidates all refresh tokens for the account",
      "item": [
        {
          "name": "Request Magic Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/magic-link/request",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "magic-link", "request"]
            },
            "description": "Sends an 8-digit OTP to the supplied email address. Rate-limited to 5 requests per 60 seconds per IP. In the development environment the OTP is also printed to the server console."
          },
          "response": [
            {
              "name": "200 OK — code sent",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Magic link code sent to test@example.com\"\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "429 Too Many Requests",
              "status": "Too Many Requests",
              "code": 429,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 429,\n  \"message\": \"ThrottlerException: Too Many Requests\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Magic link request accepted or rate limited', function () {",
                  "  pm.expect([200, 201, 429]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify Magic Link",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"code\": \"12345678\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/magic-link/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "magic-link", "verify"]
            },
            "description": "Verifies the 8-digit OTP. On success returns a JWT `accessToken` (short-lived) and a `refreshToken` (long-lived). The test script automatically saves both tokens to collection variables."
          },
          "response": [
            {
              "name": "200 OK — tokens returned",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ1c3JfMDFIWFlaQUJDREVGR0hJSiIsImVtYWlsIjoidGVzdEBleGFtcGxlLmNvbSIsImlhdCI6MTc0MTAwMDAwMCwiZXhwIjoxNzQxMDAzNjAwfQ.signature\",\n  \"refreshToken\": \"rt_01HXYZABCDEFGHIJ_longopaquestringhere\",\n  \"user\": {\n    \"id\": \"usr_01HXYZABCDEFGHIJ\",\n    \"email\": \"test@example.com\",\n    \"displayName\": null,\n    \"createdAt\": \"2026-03-04T12:00:00.000Z\",\n    \"updatedAt\": \"2026-03-04T12:00:00.000Z\"\n  }\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "401 Unauthorized — invalid or expired code",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Invalid or expired code\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Verify returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains accessToken and refreshToken', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "  pm.expect(json).to.have.property('refreshToken');",
                  "  pm.expect(json).to.have.property('user');",
                  "});",
                  "",
                  "// Save tokens to collection variables for subsequent requests",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', json.refreshToken);",
                  "  console.log('Tokens saved to collection variables.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Exchanges a valid refresh token for a new access token. The old refresh token is consumed (rotation). The test script saves the new `access_token` (and `refresh_token` if returned) back to collection variables."
          },
          "response": [
            {
              "name": "200 OK — new access token",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ1c3JfMDFIWFlaQUJDREVGR0hJSiIsImVtYWlsIjoidGVzdEBleGFtcGxlLmNvbSIsImlhdCI6MTc0MTAwMzYwMCwiZXhwIjoxNzQxMDA3MjAwfQ.newsignature\"\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "401 Unauthorized — expired or revoked refresh token",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Invalid or expired refresh token\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains accessToken', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "});",
                  "",
                  "// Persist the rotated tokens",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.accessToken);",
                  "  if (json.refreshToken) {",
                  "    pm.collectionVariables.set('refresh_token', json.refreshToken);",
                  "  }",
                  "  console.log('Rotated access_token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout (single session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Revokes a single refresh token. The user remains logged in on other devices. Requires a valid JWT in the Authorization header."
          },
          "response": [
            {
              "name": "200 OK — token revoked",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"message\": \"Refresh token revoked\"\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Unauthorized\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout (all sessions)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/session",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "session"]
            },
            "description": "Invalidates ALL refresh tokens for the authenticated user — equivalent to signing out on every device. Returns 204 No Content on success."
          },
          "response": [
            {
              "name": "204 No Content — all sessions invalidated",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": "",
              "_postman_previewlanguage": "text"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Unauthorized\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout all returns 204', function () {",
                  "  pm.response.to.have.status(204);",
                  "});",
                  "",
                  "// Clear saved tokens — they are now invalid",
                  "if (pm.response.code === 204) {",
                  "  pm.collectionVariables.set('access_token', '');",
                  "  pm.collectionVariables.set('refresh_token', '');",
                  "  console.log('All tokens cleared from collection variables.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "description": "Authenticated user profile operations. All requests require `Bearer {{access_token}}`.",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "me"]
            },
            "description": "Returns the authenticated user's profile and preferences."
          },
          "response": [
            {
              "name": "200 OK — user profile",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": \"usr_01HXYZABCDEFGHIJ\",\n  \"email\": \"test@example.com\",\n  \"displayName\": \"Test User\",\n  \"createdAt\": \"2026-03-04T12:00:00.000Z\",\n  \"updatedAt\": \"2026-03-04T12:00:00.000Z\",\n  \"preferences\": {\n    \"theme\": \"system\",\n    \"pushNotificationsEnabled\": true\n  }\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Unauthorized\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get user returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains user id and email', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Updated Name\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user", "me"]
            },
            "description": "Updates the authenticated user's profile fields. Only the supplied fields are changed (partial update). Returns the full updated user object."
          },
          "response": [
            {
              "name": "200 OK — updated user",
              "status": "OK",
              "code": 200,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": \"usr_01HXYZABCDEFGHIJ\",\n  \"email\": \"test@example.com\",\n  \"displayName\": \"Updated Name\",\n  \"createdAt\": \"2026-03-04T12:00:00.000Z\",\n  \"updatedAt\": \"2026-03-04T12:05:00.000Z\",\n  \"preferences\": {\n    \"theme\": \"system\",\n    \"pushNotificationsEnabled\": true\n  }\n}",
              "_postman_previewlanguage": "json"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"statusCode\": 401,\n  \"message\": \"Unauthorized\"\n}",
              "_postman_previewlanguage": "json"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Update user returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('displayName was updated', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.displayName).to.eql('Updated Name');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
