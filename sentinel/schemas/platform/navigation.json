{
  "$sentinel": "1.0",
  "type": "navigation",
  "description": "App navigation structure",
  "tabs": [],
  "flows": [
    {
      "id": "auth",
      "screens": ["welcome", "email-input", "code-entry"],
      "entry": "welcome"
    },
    {
      "id": "main",
      "screens": ["home"],
      "entry": "home"
    }
  ],
  "deeplinks": [
    {
      "pattern": "/auth/verify",
      "params": ["linkToken", "challengeId", "code"],
      "navigatesTo": "code-entry",
      "description": "Auth resume deep link from email. Clients store the payload at app scope, then resume auth when the auth flow is ready."
    }
  ]
}
